# Netlify / Supabase environment variables
# Copy this file to .env and fill in your real values.
# Never commit the actual .env file — it is listed in .gitignore.

# Stripe secret key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (from https://dashboard.stripe.com/webhooks)
# Used by netlify/functions/stripe-webhook.js to verify event authenticity.
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase project URL (from Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (from Supabase dashboard → Settings → API)
# Used only in Netlify serverless functions — never exposed to the browser.
SUPABASE_SERVICE_KEY=eyJ...
